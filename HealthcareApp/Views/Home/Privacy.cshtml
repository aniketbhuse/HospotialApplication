<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Random Large HTML</title>
  <style>
    body { font-family: Arial; background:#f4f4f4; margin:0; }
    .container { width:90%; margin:auto; }
    .card { background:#fff; padding:20px; margin:10px; border-radius:10px; }
    .grid { display:grid; grid-template-columns: repeat(3,1fr); gap:10px; }
    .btn { padding:10px; background:#007bff; color:#fff; border:none; }
  </style>
</head>
<body>

<header class="card">
  <h1>Random Large HTML Page</h1>
  <p>This is a generated large HTML file</p>
</header>

<div class="container">

  <!-- SECTION LOOP START -->
  
  <!-- SECTION 1 -->
  <section class="card">
    <h2>Section 1</h2>
    <div class="grid">
      <div class="card">Item 1A</div>
      <div class="card">Item 1B</div>
      <div class="card">Item 1C</div>
    </div>
    <button class="btn">Click</button>
  </section>

  <!-- SECTION 2 -->
  <section class="card">
    <h2>Section 2</h2>
    <div class="grid">
      <div class="card">Item 2A</div>
      <div class="card">Item 2B</div>
      <div class="card">Item 2C</div>
    </div>
    <button class="btn">Click</button>
  </section>

  <!-- SECTION 3 -->
  <section class="card">
    <h2>Section 3</h2>
    <div class="grid">
      <div class="card">Item 3A</div>
      <div class="card">Item 3B</div>
      <div class="card">Item 3C</div>
    </div>
    <button class="btn">Click</button>
  </section>

  <!-- TABLE -->
  <section class="card">
    <h2>Random Table</h2>
    <table border="1" width="100%">
      <tr><th>ID</th><th>Name</th><th>Value</th></tr>
      <tr><td>1</td><td>Alpha</td><td>100</td></tr>
      <tr><td>2</td><td>Beta</td><td>200</td></tr>
      <tr><td>3</td><td>Gamma</td><td>300</td></tr>
    </table>
  </section>

  <!-- FORM -->
  <section class="card">
    <h2>Form</h2>
    <form>
      <input type="text" placeholder="Name"><br><br>
      <input type="email" placeholder="Email"><br><br>
      <textarea placeholder="Message"></textarea><br><br>
      <button class="btn">Submit</button>
    </form>
  </section>

  <!-- REPEATED BLOCKS -->
  <div class="grid">

    <div class="card">Block 1</div>
    <div class="card">Block 2</div>
    <div class="card">Block 3</div>
    <div class="card">Block 4</div>
    <div class="card">Block 5</div>
    <div class="card">Block 6</div>
    <div class="card">Block 7</div>
    <div class="card">Block 8</div>
    <div class="card">Block 9</div>
    <div class="card">Block 10</div>
    <div class="card">Block 11</div>
    <div class="card">Block 12</div>
    <div class="card">Block 13</div>
    <div class="card">Block 14</div>
    <div class="card">Block 15</div>

  </div>

  <!-- MORE RANDOM CONTENT -->
  <section class="card">
    <h2>List</h2>
    <ul>
      <li>Item A</li>
      <li>Item B</li>
      <li>Item C</li>
      <li>Item D</li>
      <li>Item E</li>
    </ul>
  </section>

  <section class="card">
    <h2>Articles</h2>
    <article class="card">Article 1 content...</article>
    <article class="card">Article 2 content...</article>
    <article class="card">Article 3 content...</article>
  </section>

  <!-- DUPLICATE MANY TIMES FOR SIZE -->
  
</div>

<footer class="card">
  <p>Footer content here</p>
</footer>

</body>
</html>

