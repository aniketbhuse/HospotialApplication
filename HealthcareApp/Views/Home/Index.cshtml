@{
    ViewData["Title"] = "Home Page";
}
<!DOCTYPE html>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Healthcare UI</title>

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

    <link rel="stylesheet" href="styles.css">
</head>
<body>

    <!-- 🔷 HERO SECTION -->
    <section class="hero">
        <div class="hero-left">
            <h1>
                Your Health Is Our Priority.<br>
                Guiding You, Every Step of<br>
                the Way to Better Health.
            </h1>
        </div>

        <div class="hero-right">
            <img src="https://images.unsplash.com/photo-1584515933487-779824d29309" alt="">
            <img src="https://images.unsplash.com/photo-1576765608535-5f04d1e3f289" alt="">
            <img src="https://images.unsplash.com/photo-1607746882042-944635dfe10e" alt="">
        </div>
    </section>

    <!-- 🔷 FEATURES SECTION -->
    <section class="features">

        <div class="feature-box">
            <div class="icon"><i class="fas fa-heartbeat"></i></div>
            <h3>Best Treatment</h3>
            <p>Experience the Pinnacle of Care. Discover the Best Treatment Options.</p>
        </div>

        <div class="feature-box">
            <div class="icon"><i class="fas fa-ambulance"></i></div>
            <h3>Emergency Help</h3>
            <p>Urgent Help, Right When You Need It. 24/7 Emergency Assistance.</p>
        </div>

        <div class="feature-box">
            <div class="icon"><i class="fas fa-user-md"></i></div>
            <h3>Qualified Doctors</h3>
            <p>Expertise You Can Trust. Meet Our Qualified Doctors Today.</p>
        </div>

        <div class="feature-box">
            <div class="icon"><i class="fas fa-hospital-user"></i></div>
            <h3>Top Medical Staff</h3>
            <p>Discover Our Dedicated Medical Team. Your Wellness Journey Begins Now.</p>
        </div>

    </section>

</body>
</html>
