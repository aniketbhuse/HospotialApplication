@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container mt-4">
    <h2>Admin Dashboard</h2>

    <div class="card p-3 mt-3">
        <h5>Welcome, @Context.Session.GetString("UserName")</h5>
        <p>Manage users, doctors, and system settings here.</p>
    </div>

    <div class="mt-4">
        <a class="btn btn-primary">Manage Users</a>
        <a class="btn btn-success">View Reports</a>
        <a class="btn btn-warning">System Settings</a>
    </div>
</div>